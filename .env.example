# Cashfree API Configuration Template
# Format: KEY=VALUE
# Copy this file to .env and fill in your production credentials.
# DO NOT commit the .env file to version control.

CASHFREE_APP_ID=your_cashfree_app_id_here
CASHFREE_SECRET_KEY=your_cashfree_secret_key_here

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/smartpay
DB_USER=root
DB_PASSWORD=your_db_password_here

# AI Matching Service
AI_SERVER_URL=http://localhost:5000/match
AI_API_KEY=your_ai_secret_token_here
